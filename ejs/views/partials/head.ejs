<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aliadas da Tesoura - Imobiliária</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    
    <!-- CSS Personalizado -->
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .page-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px;
        }
        
        .page-header h2 {
            margin: 0;
            font-weight: 600;
            color: #2b4a2a;
        }
        
        .page-header p {
            margin: 0;
            color: #636e72;
        }
        
        .content-card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        
        .form-card {
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            max-width: 700px;
            margin: 0 auto;
        }
        
        .form-card h2 {
            font-weight: 600;
            color: #2b4a2a;
        }
        
        .btn-aliadas-primario {
            background: #2b4a2a;
            color: white;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }
        
        .btn-aliadas-primario:hover {
            background: #1d361c;
            color: white;
            transform: translateY(-1px);
        }
        
        .btn-aliadas-secundario {
            background: #dfe6e9;
            color: #2b4a2a;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }
        
        .btn-aliadas-secundario:hover {
            background: #b2bec3;
            color: #1d361c;
        }
        
        .table-aliadas {
            margin-bottom: 0;
        }
        
        .table-aliadas thead th {
            background: #2b4a2a;
            color: white;
            font-weight: 600;
            border-bottom: 2px solid #1d361c;
            padding: 12px 16px;
        }
        
        .table-aliadas tbody td {
            padding: 12px 16px;
            vertical-align: middle;
        }
        
        .badge-status {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
        }
        
        .badge-verde {
            background: #2b4a2a;
            color: white;
        }
        
        .badge-laranja {
            background: #fff3cd;
            color: #856404;
        }
        
        .btn-icon-action {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border: none;
            border-radius: 8px;
            background: transparent;
            color: #636e72;
            transition: all 0.2s;
            text-decoration: none;
        }
        
        .btn-icon-action:hover {
            background: #e9ecef;
            color: #2b4a2a;
        }
        
        .btn-icon-action.danger:hover {
            background: #fee2e2;
            color: #dc2626;
        }
        .navbar.bg-dark {
            background-color: #2b4a2a !important;
        }
        .avatar-circle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: #1d361c;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }
        .summary-card { /* cards de resumo no dashboard */
            background: white;
            border-radius: 12px;
            padding: 20px 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            display: flex;
            align-items: center;
            gap: 16px;
            transition: transform 0.2s;
          }

          .summary-card:hover {
              transform: translateY(-2px);
          }

          .summary-card .icon-box {
              width: 48px;
              height: 48px;
              border-radius: 12px;
              background: #2b4a2a;
              color: white;
              display: flex;
              align-items: center;
              justify-content: center;
              font-size: 1.5rem;
          }

          .summary-label {
              font-size: 0.85rem;
              color: #636e72;
              font-weight: 500;
          }

          .summary-value {
              font-size: 1.8rem;
              font-weight: 700;
              color: #2d3436;
              line-height: 1.2;
          }
          /*login*/
          .login-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 80vh;
            padding: 20px;
        }

        .login-card {
            background: white;
            border-radius: 16px;
            padding: 40px 36px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }

        .login-logo {
            text-align: center;
            margin-bottom: 32px;
        }

        .login-logo .logo-icon {
            font-size: 3rem;
            color: #2b4a2a;
        }

        .login-logo h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #2b4a2a;
            margin: 8px 0 2px;
        }

        .login-logo p {
            color: #636e72;
            margin: 0;
            font-size: 0.9rem;
        }

        .alert-erro {
            background: #fee2e2;
            color: #dc2626;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
        }

        .alert-erro i {
            font-size: 1.1rem;
            margin-right: 8px;
}

    </style>
</head>
<body>