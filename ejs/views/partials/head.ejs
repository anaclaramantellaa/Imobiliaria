<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aliadas da Tesoura - Imobiliária</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    
    <!-- CSS Personalizado -->
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .page-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px;
        }
        
        .page-header h2 {
            margin: 0;
            font-weight: 600;
            color: #2b4a2a;
        }
        
        .page-header p {
            margin: 0;
            color: #636e72;
        }
        
        .content-card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        
        .form-card {
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            max-width: 700px;
            margin: 0 auto;
        }
        
        .form-card h2 {
            font-weight: 600;
            color: #2b4a2a;
        }
        
        .btn-aliados-primario {
            background: #2b4a2a;
            color: white;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }
        
        .btn-aliados-primario:hover {
            background: #1d361c;
            color: white;
            transform: translateY(-1px);
        }
        
        .btn-aliados-secundario {
            background: #dfe6e9;
            color: #2b4a2a;
            border: none;
            padding: 10px 28px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }
        
        .btn-aliados-secundario:hover {
            background: #b2bec3;
            color: #1d361c;
        }
        
        .table-aliados {
            margin-bottom: 0;
        }
        
        .table-aliados thead th {
            background: #2b4a2a;
            color: white;
            font-weight: 600;
            border-bottom: 2px solid #1d361c;
            padding: 12px 16px;
        }
        
        .table-aliados tbody td {
            padding: 12px 16px;
            vertical-align: middle;
        }
        
        .badge-status {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
        }
        
        .badge-verde {
            background: #2b4a2a;
            color: white;
        }
        
        .badge-laranja {
            background: #fff3cd;
            color: #856404;
        }
        
        .btn-icon-action {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border: none;
            border-radius: 8px;
            background: transparent;
            color: #636e72;
            transition: all 0.2s;
            text-decoration: none;
        }
        
        .btn-icon-action:hover {
            background: #e9ecef;
            color: #2b4a2a;
        }
        
        .btn-icon-action.danger:hover {
            background: #fee2e2;
            color: #dc2626;
        }

        /* Navbar com a nova cor */
        .navbar.bg-dark {
            background-color: #2b4a2a !important;
        }

        .avatar-circle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: #1d361c;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }
    </style>
</head>
<body>