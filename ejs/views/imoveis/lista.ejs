<%- include('../partials/head') %>
<%- include('../partials/navbar', { active: 'imoveis' }) %>

<%
// Função pra formatar a moeda
function formatarMoeda(valor) {
    if (!valor) return 'R$ 0,00';
    return new Intl.NumberFormat('pt-BR', {
        style: 'currency',
        currency: 'BRL'
    }).format(valor);
}
%>

<div class="page-container">
  <div class="page-header">
    <div>
      <h2>Imóveis</h2>
      <p>Gerencie os imóveis cadastrados</p>
    </div>
    <a href="/imoveis/novo" class="btn btn-aliadas-primario">
      <i class="bi bi-plus-lg me-1"></i> Novo imóvel
    </a>
  </div>

  <div class="content-card">
    <% if (imoveis && imoveis.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-aliados mb-0">
          <thead>
            <tr>
              <th>Zona</th>
              <th>Endereço</th>
              <th>Tipo</th>
              <th>Valor</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% imoveis.forEach(imovel => { %>
              <tr>
                <td><%= imovel.zona %></td>
                <td><%= imovel.endereco %></td>
                <td><%= imovel.tipo %></td>
                <td><%= formatarMoeda(imovel.valor) %></td>
                <td>
                  <span class="badge-status <%= imovel.status === 'disponível' ? 'badge-verde' : 'badge-laranja' %>">
                    <%= imovel.status %>
                  </span>
                </td>
                <td>
                  <a href="/imoveis/<%= imovel.id_imovel %>/editar" class="btn-icon-action" title="Editar">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form action="/imoveis/<%= imovel.id_imovel %>/excluir" method="POST" class="d-inline"
                        onsubmit="return confirm('Tem certeza que deseja excluir este imóvel?');">
                    <button type="submit" class="btn-icon-action danger" title="Excluir">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-muted mb-0">Nenhum imóvel cadastrado ainda.</p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>