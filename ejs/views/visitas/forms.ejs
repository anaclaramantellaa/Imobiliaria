<%- include('../partials/head') %>
<%- include('../partials/navbar', { active: 'visitas' }) %>

<div class="page-container">
  <div class="form-card">
    <h2><%= visita ? 'Editar visita' : 'Nova visita' %></h2>
    <p>Preencha as informações</p>

    <form
      action="<%= visita ? '/visitas/' + visita.id_visita + '?_method=PUT' : '/visitas' %>"
      method="POST"
      class="form-aliados"
    >
      <div class="row g-3">
        <div class="col-md-6">
          <label for="clienteId">Cliente</label>
          <select class="form-select" id="clienteId" name="id_cliente" required>
            <option value="" disabled <%= !visita ? 'selected' : '' %>>Selecionar...</option>
            <% clientes.forEach(c => { %>
              <option value="<%= c.id_cliente %>" <%= visita && visita.id_cliente === c.id_cliente ? 'selected' : '' %>>
                <%= c.nome %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-6">
          <label for="data">Data</label>
          <input type="date" class="form-control" id="data_visita" name="data_visita"
                 value="<%= visita ? visita.data_visita : '' %>" required>
        </div>

        <div class="col-md-6">
          <label for="imovelId">Imóvel</label>
          <select class="form-select" id="imovelId" name="id_imovel" required>
            <option value="" disabled <%= !visita ? 'selected' : '' %>>Selecionar...</option>
            <% imoveis.forEach(i => { %>
              <option value="<%= i.id_imovel %>" <%= visita && visita.id_imovel === i.id_imovel ? 'selected' : '' %>>
                <%= i.endereco %><%= i.tipo ? ' (' + i.tipo + ')' : '' %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-6">
          <label for="horario">Horário</label>
          <input type="time" class="form-control" id="horario" name="horario"
                 value="<%= visita ? visita.horario : '' %>" required>
        </div>

        <div class="col-md-6">
          <label for="observacao">Observação</label>
          <input type="text" class="form-control" id="observacao" name="observacao"
                 placeholder="Ex: Esse cliente já visitou"
                 value="<%= visita ? visita.observacao : '' %>">
        </div>

        <div class="col-md-6">
          <label for="status">Status</label>
          <select class="form-select" id="status" name="status" required>
            <option value="" disabled <%= !visita ? 'selected' : '' %>>Selecionar...</option>
            <option value="agendada" <%= visita && visita.status === 'agendada' ? 'selected' : '' %>>Agendada</option>
            <option value="realizada" <%= visita && visita.status === 'realizada' ? 'selected' : '' %>>Realizada</option>
            <option value="cancelada" <%= visita && visita.status === 'cancelada' ? 'selected' : '' %>>Cancelada</option>
          </select>
        </div>
      </div>

      <hr class="my-4" style="border-color: var(--borda);">

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-aliadas-primario">Salvar</button>
        <a href="/visitas" class="btn btn-aliadas-secundario">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>